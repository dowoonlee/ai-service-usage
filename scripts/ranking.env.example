# 랭킹 시스템 환경변수 템플릿.
#
# 사용법:
#   1. `cp scripts/ranking.env.example scripts/ranking.env`
#   2. 아래 각 값을 채움 (PRIVACY_POLICY_URL은 처리방침 호스팅 후 채워도 OK)
#   3. `scripts/package.sh`가 자동으로 `source` (다음 Phase에서 패치 예정)
#
# 보안:
#   - `scripts/ranking.env`는 `.gitignore`에 등록되어 commit되지 않음
#   - SERVICE_ROLE_KEY / HMAC_MASTER_SECRET은 클라이언트 .app에 포함되지 않음
#     → Supabase Edge Function 환경변수로만 등록 (`supabase secrets set`)
#   - URL / ANON_KEY / PRIVACY_POLICY_URL만 빌드 시 Info.plist에 주입

# ============================================================================
# 클라이언트 Info.plist 주입용 (공개돼도 안전)
# ============================================================================

# Supabase Project URL — 대시보드 우상단 "Connect" 버튼 또는 Settings → Data API
# 예: https://abcdefghijklmnop.supabase.co
export SUPABASE_URL=""

# Supabase anon (public) key — 브라우저/클라이언트 노출 안전, RLS가 권한 통제.
# 신규 UI라면 sb_publishable_... 키를 써도 무방.
export SUPABASE_ANON_KEY=""

# 처리방침 페이지 URL (Notion publish 등). 비어있어도 빌드는 가능하나 옵트인
# 화면의 "처리방침 보기" 링크가 비활성화됨. 호스팅 후 채워서 재빌드.
export PRIVACY_POLICY_URL=""

# ============================================================================
# Supabase Edge Function 전용 (절대 클라이언트 미포함)
# ============================================================================

# Supabase service_role key — 서버측 모든 권한. 절대 .app 번들에 포함 금지.
# 사용처: Edge Function 배포 / DB schema 적용 시 `supabase` CLI 인증.
export SUPABASE_SERVICE_ROLE_KEY=""

# HMAC master secret — 클라이언트 per-install 키 derive에 사용 (32바이트 base64).
# 생성: `openssl rand -base64 32`
export HMAC_MASTER_SECRET=""

# Supabase Project Reference ID — 대시보드 URL의 /project/<ref> 부분.
# `supabase link --project-ref <ref>` 에 사용.
export SUPABASE_PROJECT_REF=""
